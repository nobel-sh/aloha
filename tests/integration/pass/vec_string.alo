fun main() -> void {
    imut arena = arena_new();
    imut names = vec_string_new(arena);

    vec_string_push(names, "a");
    vec_string_push(names, "bb");
    vec_string_push(names, "ccc");
    vec_string_push(names, "dddd");
    vec_string_push(names, "eeeee");
    vec_string_push(names, "ffffff");
    vec_string_push(names, "ggggggg");
    vec_string_push(names, "hhhhhhhh");
    vec_string_push(names, "iiiiiiiii");
    vec_string_push(names, "jjjjjjjjjj");

    assert_msg(vec_string_len(names) == 10, "vec string len works");
    assert_msg(aloha_sys_strlen(vec_string_get(names, 1)) == 2, "vec string get works");
    assert_msg(aloha_sys_strlen(vec_string_get(names, 9)) == 10, "vec string growth preserves values");

    vec_string_set(names, 5, "updated");
    assert_msg(aloha_sys_strlen(vec_string_get(names, 5)) == 7, "vec string set works");

    arena_free_all(arena);
}
