fun main() -> void {
    imut arena = arena_new();
    imut vec = vec_int_new(arena);
    
    vec_int_push(vec, 1);  
    vec_int_push(vec, 3);  
    vec_int_push(vec, 3);  
    vec_int_push(vec, 7);  
    vec_int_push(vec, 3);  
    vec_int_push(vec, 3);  
    vec_int_push(vec, 1);  
    vec_int_push(vec, 3);  
    vec_int_push(vec, 3);  
    vec_int_push(vec, 7);  
 

    assert_msg(vec_int_len(vec)==10, "vec len works");
    assert_msg(vec_int_get(vec, 1)==3, "vec get works");
    assert_msg(vec_int_get(vec, 9) == 7, "vec growth preserves values");

    vec_int_set(vec, 5, 8);
    assert_msg(vec_int_get(vec, 5) == 8, "vec set works");
    assert_msg(vec_int_index_of(vec, 8) == 5, "vec int index_of finds updated value");
    assert_msg(vec_int_index_of(vec, 99) == -1, "vec int index_of missing returns -1");
    assert_msg(vec_int_contains(vec, 7), "vec int contains finds existing value");
    assert_msg(vec_int_contains(vec, 99) == false, "vec int contains rejects missing value");

    arena_free_all(arena);
}
